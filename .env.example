# ============================================================================
# Slowbooks Pro 2026 — Environment Variables
# Copy to .env and customize: cp .env.example .env
# ============================================================================

# --- Native Linux Install ---
# DATABASE_URL=postgresql://bookkeeper:bookkeeper@localhost:5432/bookkeeper

# --- Docker Install ---
# These are used by docker-compose.yml (no need to change for default setup)
POSTGRES_USER=bookkeeper
POSTGRES_PASSWORD=bookkeeper
POSTGRES_DB=bookkeeper

# Application
APP_HOST=0.0.0.0
APP_PORT=3001
APP_DEBUG=false

# Company Info (can also be set in Settings UI after startup)
COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
DEFAULT_TERMS=Net 30
DEFAULT_TAX_RATE=0.0
